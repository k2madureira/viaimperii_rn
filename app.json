{
  "expo": {
    "name": "Via Imperii",
    "slug": "via-imperii",
    "scheme": "viaimperii",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.viaimperii.app"
    },
    "android": {
      "package": "com.viaimperii.app",
      "adaptiveIcon": {
        "backgroundColor": "#8B1A2B",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Usamos sua localização para situá-lo em uma província do Império e mostrar a presença das legiões na sua região."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "cadbb3d9-9dba-4d40-839c-a2fd7a09ff2b"
      }
    }
  }
}
